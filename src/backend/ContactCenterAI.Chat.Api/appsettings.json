{
  "ConnectionStrings": {
    "ChatDatabase": "Host=localhost;Port=5433;Database=contactcenterai_chat;Username=postgres;Password=postgres"
  },
  "Authentication": {
    "Provider": "Local"
  },
  "Auth0": {
    "Domain": "",
    "Audience": "https://contactcenterai-api"
  },
  "Jwt": {
    "Issuer": "ContactCenterAI",
    "Audience": "ContactCenterAI.Client",
    "SecretKey": "CHANGE_ME_TO_A_LONG_RANDOM_SECRET_KEY_AT_LEAST_32_CHARS"
  },
  "CoreApi": {
    "BaseUrl": "http://localhost:8080",
    "TimeoutSeconds": 30
  },
  "Gemini": {
    "ApiKey": "",
    "ChatModel": "gemini-2.5-flash"
  },
  "Cors": {
    "Origins": [ "http://localhost:5173" ]
  },
  "Serilog": {
    "MinimumLevel": {
      "Default": "Information",
      "Override": {
        "Microsoft": "Warning",
        "Microsoft.AspNetCore": "Warning"
      }
    }
  },
  "AllowedHosts": "*"
}
