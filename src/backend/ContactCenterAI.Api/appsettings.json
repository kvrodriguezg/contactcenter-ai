{
  "ConnectionStrings": {
    "DefaultConnection": "Host=localhost;Port=5432;Database=contactcenterai;Username=postgres;Password=postgres"
  },
  "Jwt": {
    "Issuer": "ContactCenterAI",
    "Audience": "ContactCenterAI.Client",
    "SecretKey": "CHANGE_ME_TO_A_LONG_RANDOM_SECRET_KEY_AT_LEAST_32_CHARS",
    "AccessTokenExpirationMinutes": 60,
    "RefreshTokenExpirationDays": 7
  },
  "Authentication": {
    "Provider": "Local"
  },
  "Auth0": {
    "Domain": "",
    "Audience": "https://contactcenterai-api"
  },
  "Cors": {
    "Origins": [ "http://localhost:5173" ]
  },
  "Ai": {
    "Provider": "Gemini"
  },
  "Gemini": {
    "ApiKey": "",
    "EmbeddingsModel": "gemini-embedding-001",
    "ChatModel": "gemini-2.5-flash",
    "EmbeddingDimensions": 1536
  },
  "DocumentStorage": {
    "BasePath": "storage/documents"
  },
  "Serilog": {
    "MinimumLevel": {
      "Default": "Information",
      "Override": {
        "Microsoft": "Warning",
        "Microsoft.AspNetCore": "Warning",
        "Microsoft.EntityFrameworkCore": "Warning"
      }
    }
  },
  "AllowedHosts": "*"
}
