# =============================================================================
# ContactCenterAI — plantilla de variables de entorno (SOLO EJEMPLO LOCAL)
# =============================================================================
# 1) Copiar:  cp .env.example .env   (PowerShell: Copy-Item .env.example .env)
# 2) Completar GEMINI_API_KEY y, si aplica, Auth0.
# 3) NUNCA versionar .env ni pegar claves reales en este archivo.
# 4) Credenciales postgres/guest abajo son EXCLUSIVAS para desarrollo local.
# 5) En producción usar contraseñas fuertes, AUTH_PROVIDER=Auth0 y
#    ASPNETCORE_ENVIRONMENT=Production (el seeder de usuarios demo no corre fuera de Development).
# =============================================================================

# PostgreSQL (local / Docker Compose de desarrollo)
POSTGRES_DB=contactcenterai
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_PORT=5432

# Chat PostgreSQL (local)
CHAT_POSTGRES_DB=contactcenterai_chat
CHAT_POSTGRES_USER=postgres
CHAT_POSTGRES_PASSWORD=postgres

# API
API_PORT=8080
CHAT_API_PORT=8081
BFF_PORT=8082
# Development: habilita seeder demo. Production: no crear usuarios seed.
ASPNETCORE_ENVIRONMENT=Development

# Autenticación: Local | Auth0
AUTH_PROVIDER=Local
AUTH0_DOMAIN=
AUTH0_AUDIENCE=https://contactcenterai-api

# JWT local (solo cuando AUTH_PROVIDER=Local)
JWT_ISSUER=ContactCenterAI
JWT_AUDIENCE=ContactCenterAI.Client
JWT_SECRET_KEY=DEV_ONLY_SECRET_KEY_CHANGE_IN_PRODUCTION_123456

# Chat service mode: Embedded | External
CHAT_SERVICE_MODE=Embedded

# Frontend
WEB_PORT=5173
WEB_ORIGIN=http://localhost:5173
VITE_API_BASE_URL=http://localhost:8080
VITE_AUTH_PROVIDER=Local
VITE_AUTH0_DOMAIN=
VITE_AUTH0_CLIENT_ID=
VITE_AUTH0_AUDIENCE=https://contactcenterai-api
VITE_AUTH0_REDIRECT_URI=http://localhost:5173
VITE_CHAT_SERVICE_MODE=Embedded
VITE_CHAT_API_BASE_URL=http://localhost:8081
VITE_GRAPHQL_URL=/graphql

# Proveedor de IA (Gemini)
AI_PROVIDER=Gemini
GEMINI_API_KEY=
GEMINI_EMBEDDINGS_MODEL=gemini-embedding-001
GEMINI_CHAT_MODEL=gemini-2.5-flash
GEMINI_EMBEDDING_DIMENSIONS=1536

# Document storage
DocumentStorage__BasePath=storage/documents

# Document processing (Worker)
DocumentProcessing__IntervalSeconds=30
DocumentProcessing__ChunkSize=1000
DocumentProcessing__ChunkOverlap=150
DocumentProcessing__BatchSize=5

# Messaging / RabbitMQ (feature 5)
# MESSAGING_ENABLED=false keeps pure DB polling (default, zero broker dependency).
# Set true to publish events + run Worker consumers.
MESSAGING_ENABLED=false
# When Messaging is enabled, set DOCUMENT_PROCESSING_POLLING_ENABLED=false to avoid constant polling.
# Keep true (with a longer interval) only if you want DB reconciliation as a safe fallback.
DOCUMENT_PROCESSING_INTERVAL_SECONDS=30
DOCUMENT_PROCESSING_POLLING_ENABLED=true
# RabbitMQ connection (guest/guest is LOCAL ONLY — never use real credentials here).
RABBITMQ_HOST=rabbitmq
RABBITMQ_PORT=5672
RABBITMQ_USER=guest
RABBITMQ_PASSWORD=guest
RABBITMQ_VHOST=/
# Management UI is bound to 127.0.0.1 in docker-compose (local/restricted).
RABBITMQ_MANAGEMENT_PORT=15672
