<?xml version="1.0" encoding="utf-8"?>
<package xmlns="http://schemas.microsoft.com/packaging/2013/05/nuspec.xsd">
  <metadata>
    <id>Pgvector</id>
    <version>0.3.2</version>
    <authors>ankane</authors>
    <license type="expression">MIT</license>
    <licenseUrl>https://licenses.nuget.org/MIT</licenseUrl>
    <icon>icon.png</icon>
    <readme>README.md</readme>
    <projectUrl>https://github.com/pgvector/pgvector-dotnet</projectUrl>
    <description>pgvector support for Npgsql</description>
    <repository type="git" commit="9ce301b23ec0cb6e3dea254fd4726047fa07e79c" />
    <dependencies>
      <group targetFramework=".NETFramework4.6.2">
        <dependency id="Npgsql" version="8.0.5" exclude="Build,Analyzers" />
      </group>
      <group targetFramework="net6.0">
        <dependency id="Npgsql" version="8.0.5" exclude="Build,Analyzers" />
      </group>
      <group targetFramework=".NETStandard2.0">
        <dependency id="Npgsql" version="8.0.5" exclude="Build,Analyzers" />
      </group>
    </dependencies>
  </metadata>
</package>