<?xml version="1.0" encoding="utf-8"?>
<package xmlns="http://schemas.microsoft.com/packaging/2013/05/nuspec.xsd">
  <metadata>
    <id>Pgvector.EntityFrameworkCore</id>
    <version>0.3.0</version>
    <authors>ankane</authors>
    <license type="expression">MIT</license>
    <licenseUrl>https://licenses.nuget.org/MIT</licenseUrl>
    <icon>icon.png</icon>
    <readme>README.md</readme>
    <projectUrl>https://github.com/pgvector/pgvector-dotnet</projectUrl>
    <description>pgvector support for Entity Framework Core</description>
    <repository type="git" commit="2d4f8d4e3792dc55067be1c04f9d9503b004d34c" />
    <dependencies>
      <group targetFramework="net8.0">
        <dependency id="Pgvector" version="0.3.2" exclude="Build,Analyzers" />
        <dependency id="Npgsql.EntityFrameworkCore.PostgreSQL" version="9.0.1" exclude="Build,Analyzers" />
      </group>
    </dependencies>
  </metadata>
</package>