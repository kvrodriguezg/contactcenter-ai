<?xml version="1.0" encoding="utf-8"?>
<package xmlns="http://schemas.microsoft.com/packaging/2013/05/nuspec.xsd">
  <metadata>
    <id>PDFiumZ</id>
    <version>152.0.7934.1</version>
    <authors>DJGosnell</authors>
    <license type="expression">Apache-2.0</license>
    <licenseUrl>https://licenses.nuget.org/Apache-2.0</licenseUrl>
    <icon>icon.png</icon>
    <projectUrl>https://github.com/Dtronix/PDFiumZ</projectUrl>
    <description>PDFiumZ is a wrapper for pinvoke bindings to allow for direct PDFium usage in all languages which support .NET Standard 2.1. Includes the runtime native binary files for Linux-x64, Osx-x64, Win-x86 &amp; Win-x64 targets.</description>
    <tags>pinvoke dotnet interop pdf pdfium</tags>
    <repository type="git" url="https://github.com/Dtronix/PDFiumZ" commit="a49252a409ca3a09b11166744f6533d0e275a961" />
    <dependencies>
      <group targetFramework="net10.0">
        <dependency id="bblanchon.PDFium.Linux" version="152.0.7934" include="Runtime,Compile,Build,Native,ContentFiles,BuildTransitive" />
        <dependency id="bblanchon.PDFium.Win32" version="152.0.7934" include="Runtime,Compile,Build,Native,ContentFiles,BuildTransitive" />
        <dependency id="bblanchon.PDFium.macOS" version="152.0.7934" include="Runtime,Compile,Build,Native,ContentFiles,BuildTransitive" />
      </group>
      <group targetFramework="net9.0">
        <dependency id="bblanchon.PDFium.Linux" version="152.0.7934" include="Runtime,Compile,Build,Native,ContentFiles,BuildTransitive" />
        <dependency id="bblanchon.PDFium.Win32" version="152.0.7934" include="Runtime,Compile,Build,Native,ContentFiles,BuildTransitive" />
        <dependency id="bblanchon.PDFium.macOS" version="152.0.7934" include="Runtime,Compile,Build,Native,ContentFiles,BuildTransitive" />
      </group>
      <group targetFramework=".NETStandard2.0">
        <dependency id="System.Memory" version="4.6.3" exclude="Build,Analyzers" />
        <dependency id="System.Runtime.CompilerServices.Unsafe" version="6.1.2" exclude="Build,Analyzers" />
        <dependency id="bblanchon.PDFium.Linux" version="152.0.7934" include="Runtime,Compile,Build,Native,ContentFiles,BuildTransitive" />
        <dependency id="bblanchon.PDFium.Win32" version="152.0.7934" include="Runtime,Compile,Build,Native,ContentFiles,BuildTransitive" />
        <dependency id="bblanchon.PDFium.macOS" version="152.0.7934" include="Runtime,Compile,Build,Native,ContentFiles,BuildTransitive" />
      </group>
      <group targetFramework=".NETStandard2.1">
        <dependency id="System.Runtime.CompilerServices.Unsafe" version="6.1.2" exclude="Build,Analyzers" />
        <dependency id="bblanchon.PDFium.Linux" version="152.0.7934" include="Runtime,Compile,Build,Native,ContentFiles,BuildTransitive" />
        <dependency id="bblanchon.PDFium.Win32" version="152.0.7934" include="Runtime,Compile,Build,Native,ContentFiles,BuildTransitive" />
        <dependency id="bblanchon.PDFium.macOS" version="152.0.7934" include="Runtime,Compile,Build,Native,ContentFiles,BuildTransitive" />
      </group>
    </dependencies>
  </metadata>
</package>