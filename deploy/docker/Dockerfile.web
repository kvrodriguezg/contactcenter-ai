FROM node:22-alpine AS build
WORKDIR /app

COPY src/frontend/contact-center-web/package*.json ./
RUN npm ci

COPY src/frontend/contact-center-web/ ./
ARG VITE_API_BASE_URL=http://localhost:8080
ARG VITE_AUTH_PROVIDER=Local
ARG VITE_AUTH0_DOMAIN=
ARG VITE_AUTH0_CLIENT_ID=
ARG VITE_AUTH0_AUDIENCE=https://contactcenterai-api
ARG VITE_AUTH0_REDIRECT_URI=http://localhost:5173
ARG VITE_CHAT_SERVICE_MODE=Embedded
ARG VITE_CHAT_API_BASE_URL=http://localhost:8081
ENV VITE_API_BASE_URL=$VITE_API_BASE_URL
ENV VITE_AUTH_PROVIDER=$VITE_AUTH_PROVIDER
ENV VITE_AUTH0_DOMAIN=$VITE_AUTH0_DOMAIN
ENV VITE_AUTH0_CLIENT_ID=$VITE_AUTH0_CLIENT_ID
ENV VITE_AUTH0_AUDIENCE=$VITE_AUTH0_AUDIENCE
ENV VITE_AUTH0_REDIRECT_URI=$VITE_AUTH0_REDIRECT_URI
ENV VITE_CHAT_SERVICE_MODE=$VITE_CHAT_SERVICE_MODE
ENV VITE_CHAT_API_BASE_URL=$VITE_CHAT_API_BASE_URL
RUN npm run build

FROM nginx:1.27-alpine AS final
COPY deploy/docker/nginx.conf /etc/nginx/conf.d/default.conf
COPY --from=build /app/dist /usr/share/nginx/html
EXPOSE 80
ENTRYPOINT ["nginx", "-g", "daemon off;"]
